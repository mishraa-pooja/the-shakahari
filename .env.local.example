# Supabase (create project at supabase.com, then copy from Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# WhatsApp number for floating button (country code + number, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# Google Maps — location picker in checkout
# Get from console.cloud.google.com > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaxxxxxxx

# WhatsApp Cloud API (webhook + outbound replies) — server-only, never expose tokens to client
WHATSAPP_VERIFY_TOKEN=your_random_verify_string
WHATSAPP_ACCESS_TOKEN=EAAxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Optional: bypass RLS for webhook inserts (recommended in production)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci... (Settings → API → service_role)
