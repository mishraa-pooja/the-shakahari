# Public site URL (optional — used for absolute Open Graph / social preview images)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (create project at supabase.com, then copy from Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# WhatsApp number for floating button (country code + number, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# Google Maps — location picker in checkout
# Get from console.cloud.google.com > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaxxxxxxx

# WhatsApp Cloud API (webhook + outbound replies) — server-only, never expose tokens to client
WHATSAPP_VERIFY_TOKEN=your_random_verify_string
WHATSAPP_ACCESS_TOKEN=EAAxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# WhatsApp OTP after order (encrypted cookie session — no extra DB table)
# Long random string (min 16 chars)
WHATSAPP_OTP_SECRET=generate_a_long_random_string_here
# Optional: approved template name + language; body must have one {{1}} for the code (Meta Business Suite)
WHATSAPP_OTP_TEMPLATE_NAME=shaka_hari_otp
WHATSAPP_OTP_TEMPLATE_LANG=en

# Admin dashboard passphrase (used for /admin access — set a strong secret)
ADMIN_SECRET=your_admin_passphrase_here

# Required for: phone_verified_profiles (OTP verify), customer_order_analytics (order aggregates),
# and recommended for whatsapp_messages webhook inserts. Server-only — never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci... (Settings → API → service_role)
